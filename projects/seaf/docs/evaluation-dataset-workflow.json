  {
    "id": "ev-workflow-002",
    "name": "节点失败-熔断降级",
    "agent_type": "workflow",
    "description": "测试中间节点失败时的熔断降级处理",
    "user_query": "帮我查数据并生成报告",
    "expected_workflow": [
      { "node": "data_fetch", "expected_duration": "< 3s", "required": true },
      { "node": "analysis", "expected_duration": "< 5s", "required": false, "fallback": "跳过分析直接生成摘要" },
      { "node": "report_generation", "expected_duration": "< 5s", "required": true }
    ],
    "failure_injection": {
      "node": "analysis",
      "failure_type": "timeout",
      "timeout": "3s"
    },
    "expected_behavior": "analysis节点超时应自动降级，流程继续，report_generation基于原始数据生成",
    "wrong_patterns": [
      { "pattern": "analysis失败后整个工作流终止", "severity": "critical" },
      { "pattern": "没有降级策略，直接返回错误", "severity": "high" }
    ],
    "evaluation_dimensions": [
      { "dimension": "流程完整性", "weight": 0.25 },
      { "dimension": "节点失败处理", "weight": 0.35 },
      { "dimension": "响应时间合理性", "weight": 0.2 },
      { "dimension": "结果质量", "weight": 0.2 }
    ],
    "tags": ["故障处理", "熔断", "降级"],
    "difficulty": "hard"
  },
  {
    "id": "ev-workflow-003",
