    "agent_type": "workflow",
    "description": "测试可并行节点是否真正并行执行",
    "user_query": "帮我同时查询这三只股票的今日股价：腾讯、阿里、字节",
    "expected_workflow": [
      { "node": "fetch_tencent", "parallel_group": "stock_fetch", "expected_duration": "< 2s" },
      { "node": "fetch_alibaba", "parallel_group": "stock_fetch", "expected_duration": "< 2s" },
      { "node": "fetch_bytedance", "parallel_group": "stock_fetch", "expected_duration": "< 2s" },
      { "node": "aggregate", "expected_duration": "< 1s", "depends_on": "stock_fetch" }
    ],
    "expected_total_duration": "< 3.5s",
    "wrong_patterns": [
      { "pattern": "串行查询三只股票", "severity": "medium", "expected_time_ratio": "3x" }
    ],
    "evaluation_dimensions": [
      { "dimension": "流程完整性", "weight": 0.25 },
      { "dimension": "节点失败处理", "weight": 0.2 },
      { "dimension": "响应时间合理性", "weight": 0.35 },
      { "dimension": "结果质量", "weight": 0.2 }
    ],
    "performance_threshold": {
      "p95_latency": "3.5s",
      "parallel_efficiency": "> 70%"
    },
    "tags": ["并行执行", "性能优化", "效率"],
    "difficulty": "medium"
  },
  {
